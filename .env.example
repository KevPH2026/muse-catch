# 想解锁更多模型？（100+ 模型智能路由）
#   → 到 https://tokenrouter.com 注册获取 API Key
#   → 填入下方 TR_API_KEY
# ============================================

# TokenRouter API (optional — get key at https://tokenrouter.com)
TR_BASE_URL=https://api.tokenrouter.com/v1
TR_API_KEY=*** Local Ollama (optional — privacy-first, data stays on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
