# ============================================
# Muse Catch — LLM Configuration
# ============================================
# 
# 两种方式任选其一：
#
# 1. TokenRouter 云端（推荐，100+模型智能路由）
#    注册获取 API Key → https://tokenrouter.com
#    TR_BASE_URL=https://api.tokenrouter.com/v1
#    TR_API_KEY=your-tokenrouter-key
#
# 2. 本地 Ollama（隐私优先，数据不出机器）
#    brew install ollama && ollama serve
#    ollama pull qwen2.5:14b
#    OLLAMA_BASE_URL=http://localhost:11434
#    OLLAMA_MODEL=qwen2.5:14b
#
# 不配置任何 Key？Muse 仍可运行（关键词提取 + 规则兜底）。
# 配置 TokenRouter → 解锁 AI 发散/分类/选题/金句配图。
# ============================================

# TokenRouter API (optional — get key at https://tokenrouter.com)
TR_BASE_URL=https://api.tokenrouter.com/v1
TR_API_KEY=

# Local Ollama (optional — privacy-first fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
